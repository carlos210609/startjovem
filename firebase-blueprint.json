{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile in the Start Jovem community.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "bio": { "type": "string", "description": "Short biography." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp." }
      },
      "required": ["name", "email", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A community post created by a user.",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "The text content of the post." },
        "authorId": { "type": "string", "description": "UID of the user who created the post." },
        "authorName": { "type": "string", "description": "Display name of the author." },
        "authorPhoto": { "type": "string", "description": "Profile picture of the author." },
        "likesCount": { "type": "number", "description": "Total number of likes." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Post creation timestamp." }
      },
      "required": ["content", "authorId", "authorName", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a community post.",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "Text content of the comment." },
        "postId": { "type": "string", "description": "ID of the parent post." },
        "authorId": { "type": "string", "description": "UID of the commenter." },
        "authorName": { "type": "string", "description": "Display name of the commenter." },
        "authorPhoto": { "type": "string", "description": "Profile picture of the commenter." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Comment creation timestamp." }
      },
      "required": ["content", "postId", "authorId", "authorName", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles stored by UID."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Global community posts."
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Global comments collection."
    }
  }
}
